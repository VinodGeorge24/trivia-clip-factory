# Copy to .env for local overrides. Do not commit .env.
# Do not store Telegram/OpenClaw tokens here. Telegram transport credentials
# belong to the existing global OpenClaw setup.

# Local runtime directory for SQLite, generated drafts, logs, and temporary files.
TTF_DATA_DIR=var

# SQLite database path. Relative paths resolve from the repository root/current working directory.
TTF_DB_PATH=var/trivia_factory.sqlite3

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
TTF_LOG_LEVEL=INFO

# Watermark shown near the bottom of rendered videos. Set this to your TikTok handle later.
TTF_WATERMARK_TEXT=Trivia Clip Factory

# Voiceover synthesis provider for manifest scene voiceover text.
# none keeps fully procedural audio. windows_sapi uses local Windows speech synthesis.
TTF_VOICEOVER_PROVIDER=none

# TikTok sandbox/API settings. Put real values only in local .env.
TIKTOK_ENV=sandbox
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:3455/callback/
TIKTOK_SCOPES=user.info.basic,video.upload
TIKTOK_ACCOUNT_NAME=Trivia Clip Factory
